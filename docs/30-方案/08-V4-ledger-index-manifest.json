{
  "manifest_version": "1.0.0",
  "manifest_id": "safeclaw-ledger-index",
  "phase": "slice-a-baseline",
  "description": "Ledger compatibility index baseline before any file migration.",
  "ledgers": [
    {
      "logical_id": "dev-plan",
      "legacy_path": "开发计划.md",
      "target_path": "docs/records/开发计划.md",
      "read_order": ["legacy_path"],
      "write_mode": "legacy-only",
      "cutover_state": "legacy-only"
    },
    {
      "logical_id": "mvp-progress",
      "legacy_path": "MVP_PROGRESS.md",
      "target_path": "docs/records/MVP_PROGRESS.md",
      "read_order": ["legacy_path"],
      "write_mode": "legacy-only",
      "cutover_state": "legacy-only"
    },
    {
      "logical_id": "push-log",
      "legacy_path": "PUSH_LOG.md",
      "target_path": "docs/records/PUSH_LOG.md",
      "read_order": ["legacy_path"],
      "write_mode": "legacy-only",
      "cutover_state": "legacy-only"
    }
  ],
  "conflict_policy": {
    "on_divergence": "fail-fast",
    "on_missing_target_when_legacy_only": "fallback-legacy",
    "on_missing_target_when_target_primary": "error"
  }
}
